# Wonea configuratie. Kopieer naar .env voor lokaal; zet dezelfde variabelen
# in je host (Vercel) voor productie.

# --- Database (Postgres) ---
# Lokaal: een lokale Postgres. In productie (Vercel): je Neon-connection-string.
# Vorm Neon: postgresql://<user>:<wachtwoord>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://localhost:5432/wonea

# --- Data-ingest testgebied ---
WONEA_GEMEENTE=Eindhoven
WONEA_POSTCODE4=5611,5612,5613,5614,5615,5616,5617

# --- Admin ---
# Basic-auth op /admin. Zet in productie een STERK wachtwoord.
WONEA_ADMIN_PASSWORD=wonea-dev

# --- Dev-mailbox ---
# /dev/mail toont alle uitgaande mails (incl. inloglinks). NOOIT op 1 in productie.
WONEA_DEV_MAIL=1

# --- Sessies ---
# Secret voor sessiecookies. Zet in productie een lange, willekeurige waarde.
WONEA_SESSION_SECRET=dev-secret-verander-in-productie

# --- Optioneel ---
# PDOK Locatieserver voor adres-suggest (gratis, keyless). 0 = lokaal zoeken.
WONEA_PDOK_SUGGEST=0

# Plausible analytics (uit tot je een domein invult).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Basis-URL voor links in e-mails en widget-embeds.
# Lokaal poort 4123; in productie https://wonea.nl (of je Vercel-preview-URL).
WONEA_BASE_URL=http://localhost:4123
