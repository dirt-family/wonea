# Wonea lokale configuratie. Kopieer naar .env en pas aan.

# Testgebied voor data-ingest
WONEA_GEMEENTE=Eindhoven
WONEA_POSTCODE4=5611,5612,5613,5614,5615,5616,5617

# Admin basic-auth (lokaal)
WONEA_ADMIN_PASSWORD=wonea-dev

# Dev-mailbox op /dev/mail (NOOIT aan in productie)
WONEA_DEV_MAIL=1

# Sessie-secret voor cookies (lokaal mag dit een vaste string zijn)
WONEA_SESSION_SECRET=dev-secret-verander-in-productie

# Optioneel: PDOK Locatieserver voor adres-suggest (gratis, keyless). 0 = lokaal zoeken.
WONEA_PDOK_SUGGEST=0

# Plausible analytics (Fase 6, uit tot er een key/domein is)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Basis-URL voor links in e-mails en widget-embeds
# Poort 4123 omdat 3000 (Twenty CRM) en 3100 (paperclip) op deze Mac bezet zijn.
WONEA_BASE_URL=http://localhost:4123
